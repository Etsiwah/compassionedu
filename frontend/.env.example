# CompassionEdu Frontend - Local Environment
# Copy this file to frontend/.env if you need to override defaults.

# Optional in development.
# If unset, the React dev server uses package.json proxy and calls /api.
# Set this only if your backend runs somewhere other than the local proxy.
# REACT_APP_API_URL=http://localhost:4000/api

# Optional. In development, /dev/accounts is visible automatically.
REACT_APP_SHOW_DEV_ACCOUNTS=false
