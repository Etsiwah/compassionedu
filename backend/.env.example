# CompassionEdu Backend - Local Environment
# Copy this file to backend/.env for local development.
# Do not commit real secrets.

# Server
NODE_ENV=development
PORT=4000

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/compassion_edu

# Auth
# Generate secrets with:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-me-local-access-secret
JWT_REFRESH_SECRET=change-me-local-refresh-secret
JWT_EXPIRES_IN=24h
REFRESH_TOKEN_EXPIRES_IN=30d

# CORS
# Comma-separated frontend origins allowed to call the API.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# File uploads
UPLOAD_DIR=uploads
MAX_PROFILE_PHOTO_SIZE_MB=10
MAX_CV_SIZE_MB=50
MAX_MEDIA_SIZE_MB=50
