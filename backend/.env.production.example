# CompassionEdu Backend - Production Environment
# Set these on Render, Railway, Fly.io, or your hosting provider.
# Do not commit real secrets.

# Server
NODE_ENV=production
PORT=4000

# Database
# Use sslmode=require for hosted PostgreSQL providers when required.
DATABASE_URL=postgresql://user:password@host:5432/compassion_edu?sslmode=require

# Auth
# Generate each secret independently:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_HEX
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_64_CHAR_RANDOM_HEX
JWT_EXPIRES_IN=24h
REFRESH_TOKEN_EXPIRES_IN=30d

# CORS
# Comma-separated list of deployed frontend origins.
ALLOWED_ORIGINS=https://YOUR_FRONTEND_URL.vercel.app

# File uploads
UPLOAD_DIR=uploads
MAX_PROFILE_PHOTO_SIZE_MB=10
MAX_CV_SIZE_MB=50
MAX_MEDIA_SIZE_MB=200
