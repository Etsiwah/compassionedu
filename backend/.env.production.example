# CompassionEdu Backend - Production Environment (Render)
# Use these as a template for setting environment variables on Render

# ============================================================
# SERVER CONFIGURATION
# ============================================================
NODE_ENV=production
PORT=4000

# ============================================================
# DATABASE (Supabase)
# ============================================================
# Get this from: Supabase Dashboard → Settings → Database → Connection String (URI)
# Format: postgresql://postgres:[PASSWORD]@db.xxxxx.supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.xxxxx.supabase.co:5432/postgres

# ============================================================
# AUTHENTICATION SECRETS
# ============================================================
# Generate these with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# IMPORTANT: Generate NEW secrets for production - do NOT reuse local ones!
JWT_SECRET=your-production-jwt-secret-64-characters-long-random-string-here
JWT_REFRESH_SECRET=your-production-refresh-secret-64-characters-long-random-here
JWT_EXPIRES_IN=24h
REFRESH_TOKEN_EXPIRES_IN=30d

# ============================================================
# CORS (Cross-Origin Resource Sharing)
# ============================================================
# Your Vercel frontend URL (no trailing slash)
# Example: https://compassionedu-xyz.vercel.app
ALLOWED_ORIGINS=https://your-app.vercel.app

# ============================================================
# EMAIL CONFIGURATION (Gmail SMTP)
# ============================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false

# Your Gmail address
SMTP_USER=your-email@gmail.com

# Gmail App Password (NOT your regular Gmail password!)
# Generate at: https://myaccount.google.com/apppasswords
# 16 characters, no spaces
SMTP_PASS=xxxx xxxx xxxx xxxx

# ============================================================
# APPLICATION URLS
# ============================================================
# Your Vercel frontend URL (used in emails and redirects)
FRONTEND_URL=https://your-app.vercel.app

# Your Render backend URL  
BACKEND_URL=https://your-app-name.onrender.com

# ============================================================
# GOOGLE OAUTH 2.0
# ============================================================
# Get these from: https://console.cloud.google.com
# → APIs & Services → Credentials → OAuth 2.0 Client IDs

# Example: 123456789-xxxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Example: GOCSPX-xxxxxxxxxxxxxxxxxxxxx
GOOGLE_CLIENT_SECRET=your-client-secret

# ============================================================
# FILE UPLOADS
# ============================================================
# For Render, use absolute path:
UPLOAD_DIR=/opt/render/project/src/uploads

# File size limits in megabytes
MAX_PROFILE_PHOTO_SIZE_MB=10
MAX_CV_SIZE_MB=50
MAX_MEDIA_SIZE_MB=50

# ============================================================
# INSTRUCTIONS FOR RENDER DEPLOYMENT
# ============================================================
# 
# 1. Go to: https://dashboard.render.com
# 2. Select your service → Environment
# 3. Add each variable above (without comments)
# 4. Click "Save Changes" (auto-redeploys)
#
# SECURITY NOTES:
# - Never commit this file with real values
# - Use different secrets for production vs development
# - Rotate secrets regularly
# - Keep backup of all credentials in password manager
#
# ============================================================
