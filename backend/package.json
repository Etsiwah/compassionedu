{
  "name": "compassion-edu-backend",
  "version": "1.0.0",
  "description": "CompassionEdu School Management System - Backend API",
  "main": "src/app.js",
  "scripts": {
    "start": "node start-with-migrate.js",
    "dev": "nodemon src/app.js",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "migrate": "node src/db/migrate.js",
    "seed": "node src/db/seed.js",
    "build": "echo 'No build step required for Node.js'",
    "postinstall": "echo 'Backend installed'"
  },
  "dependencies": {
    "bcryptjs": "2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.2",
    "express-session": "^1.19.0",
    "express-validator": "^7.3.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^8.0.10",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "pdfkit": "^0.15.0",
    "pg": "^8.12.0"
  },
  "devDependencies": {
    "fast-check": "^3.19.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.4",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.js",
      "**/*.test.js"
    ],
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/db/migrate.js"
    ]
  }
}
